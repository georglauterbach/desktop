#! /bin/sh

set -e -u

meson_ninja() {
  # cSpell: ignore buildtype warnlevel
  meson setup build         \
    --reconfigure           \
    --backend=ninja         \
    --buildtype=release     \
    --optimization 3        \
    --strip                 \
    --warnlevel=0           \
    --auto-features=enabled \
    --prefix="${INSTALLATION_PREFIX}" "${@}"

  ninja -C build install
}

__log "Building '${1:?Directory to build in is required}'"
( cd "${1}" ; shift 1 ; "${@}" ; )
