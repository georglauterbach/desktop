# configure I/O devices
#include "${HOME}/.config/sway/user/00-io.conf"

# -----------------------------------------------
# ----  Initialization  -------------------------
# -----------------------------------------------

# Enable XWayland support to run X11 in Wayland
xwayland enable

# Sway does not natively support in-order startup
# of applications; hence, we use a shell script
# to get rid of this limitation.
exec 'exec "${HOME}/.config/sway/init.sh"'

# -----------------------------------------------
# ----  Laptop  ---------------------------------
# -----------------------------------------------

# cSpell: ignore bindswitch
#bindswitch --locked --reload lid:on  output eDP-1 disable
#bindswitch --locked --reload lid:off output eDP-1 enable

# -----------------------------------------------
# ----  Workspaces  -----------------------------
# -----------------------------------------------

