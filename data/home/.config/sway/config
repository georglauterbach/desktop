set $wm.ws.02.name "2:02 󰨞"
set $wm.ws.03.name "3:03 "
set $wm.ws.04.name "4:04 󰇮"
set $wm.ws.05.name "5:05 "
set $wm.ws.06.name "6:06 "
set $wm.ws.07.name "7:07 "
set $wm.ws.08.name "8:08 "
set $wm.ws.09.name "9:09 "
set $wm.ws.10.name "10:10 󰊻"
set $wm.ws.11.name "11:11 "
set $wm.ws.12.name "12:12 "
set $wm.ws.13.name "13:13 "
set $wm.ws.14.name "14:14 "
set $wm.ws.15.name "15:15 "
set $wm.ws.16.name "16:16 "
set $wm.ws.17.name "17:17 "
set $wm.ws.18.name "18:18 "
set $wm.ws.19.name "19:19 "

set $wm.ws.01.key 1
set $wm.ws.02.key 2
set $wm.ws.03.key 3
set $wm.ws.04.key 4
set $wm.ws.05.key 5
set $wm.ws.06.key 6
set $wm.ws.07.key 7
set $wm.ws.08.key 8
set $wm.ws.09.key 9
set $wm.ws.10.key 0

workspace_layout default
workspace_auto_back_and_forth no

# -----------------------------------------------
# ----  Lockscreen  -----------------------------
# -----------------------------------------------

exec exec swayidle -w                      \
    timeout 600  'swaymsg exec __way_lock' \
    before-sleep 'swaymsg exec __way_lock'

# -----------------------------------------------
# ----  Design  ---------------------------------
# -----------------------------------------------

set $color.transparent          #00000000

# ----  Colors Light
set $color.light.background_dim #EBEBE4
set $color.light.background     #F5F5F2
set $color.light.foreground     #5C6A72
set $color.light.red            #F85552
set $color.light.orange         #F57D26
set $color.light.yellow         #D69A00
set $color.light.green          #8DA101
set $color.light.cyan           #35A77C
set $color.light.blue           #3A94C5
set $color.light.purple         #DF69BA

# ----  Colors Dark
set $color.dark.background_dim  #141617
set $color.dark.background      #1D2021
set $color.dark.foreground      #DDC7A1
set $color.dark.red             #EA6962
set $color.dark.orange          #E78A4E
set $color.dark.yellow          #D8A657
set $color.dark.green           #A9B665
set $color.dark.cyan            #89B482
set $color.dark.blue            #7DAEA3
set $color.dark.purple          #D3869B

#                       The border around the title bar.
#                       |                  The background of the title bar.
#                       |                  |                  The text color of the title bar.
#                       |                  |                  |                  The color used to indicate where a new window will open. In
#                       |                  |                  |                  a tiled container, this would paint the right border of the
#                       |                  |                  |                  current window  if a new window would be opened to the right.
#                       |                  |                  |                  |                         The border around the window itself.
#                       |                  |                  |                  |                         |
# class                 border             background         text               indicator                 child_border
client.focused          $color.transparent $color.transparent $color.transparent $color.light.blue         $color.light.blue
client.focused_inactive $color.transparent $color.transparent $color.transparent $color.light.blue80       $color.light.blue80
client.unfocused        $color.transparent $color.transparent $color.transparent $color.light.foregroundB0 $color.light.foregroundB0
client.urgent           $color.transparent $color.transparent $color.transparent $color.light.red          $color.light.red

# ----  Borders

smart_borders           on
default_border          pixel 2
default_floating_border pixel 2
hide_edge_borders       none

# ensure all windows - even floating ones - have a border
for_window [class=".*"]  border pixel 2
for_window [app_id=".*"] border pixel 2

# ----  Gaps

smart_gaps on
gaps inner  4
gaps outer -4

# ---- Focus

mouse_warping none
focus_follows_mouse yes
focus_on_window_activation none

# ----  Fullscreen Windows

popup_during_fullscreen smart
for_window [shell=".*"] inhibit_idle fullscreen

# ----  Floating Windows

floating_maximum_size   0 x 0
for_window [class="floating_window"] floating enable

# ---- Mouse Cursor

seat * hide_cursor 10000
seat * hide_cursor when-typing enable

# ----  Typography

set $typography.font.default   Ubuntu Sans 12
set $typography.font.monospace JetBrainsMono Nerd Font 11

# cSpell: ignore pango
font pango:$typography.font.default

# -----------------------------------------------
# ----  SwayFX  ---------------------------------
# -----------------------------------------------

#animation_duration_ms 200
#blur                  enable
#corner_radius         3
#default_dim_inactive  0.05
#shadows               disable
#titlebar_separator    disable

#layer_effects "swaync-control-center" {
#    blur enable;
#}

# -----------------------------------------------
# ----  Key Bindings  ---------------------------
# -----------------------------------------------

# ----  Meta Key Mappings

set $spr Mod4
set $alt Mod1
set $sft Shift
set $ctl Ctrl

floating_modifier $spr

# ----  Session Management

# reload Sway
bindsym $spr+$sft+r exec swaymsg reload

# lock the screen
bindsym $spr+$sft+l exec __way_lock

# session management
bindsym $spr+$sft+e exec wleave

# ----  Miscellaneous

# tile vertically or horizontally
bindsym $spr+v           split      vertical
bindsym $spr+h           split      horizontal

# fullscreen, floating and focus toggle
bindsym $spr+$sft+f      fullscreen toggle
bindsym $spr+$sft+Space  floating   toggle
bindsym $spr+$sft+t      focus      mode_toggle

# terminate a window
bindsym $spr+q           [con_id="__focused__"] kill

# application launcher
# cSpell: ignore drun combi
bindsym $spr+$ctl+Space exec rofi -show drun
bindsym $spr+Space      exec rofi -show combi

# terminal
bindsym $spr+Return     exec systemd-run --user --scope /usr/bin/x-terminal-emulator

# notification center
bindsym $spr+$sft+n     exec swaync-client --toggle-panel --skip-wait

# set power profile
bindsym $spr+$sft+p     exec __powerprofile

# ----  Navigation

bindsym $spr+Left                    focus left
