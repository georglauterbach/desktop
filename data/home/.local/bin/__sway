#! /usr/bin/env bash

set +eE -u -o pipefail
shopt -s inherit_errexit

mkdir -p /tmp/.sway/
rm -f    /tmp/.sway/sway.log   /tmp/.sway/sway.err.log
exec    >/tmp/.sway/sway.log 2>/tmp/.sway/sway.err.log

echo 'INFO  Setting up environment for Sway'

[[ -v XDG_CONFIG_HOME ]] || export XDG_CONFIG_HOME="${HOME}/.config"
[[ -v XDG_CACHE_HOME ]]  || export XDG_CACHE_HOME="${HOME}/.cache"
[[ -v XDG_DATA_HOME ]]   || export XDG_DATA_HOME="${HOME}/.local/share"
[[ -v XDG_STATE_HOME ]]  || export XDG_STATE_HOME="${HOME}/.local/state"

export WLR_RENDERER=vulkan

export XDG_CURRENT_DESKTOP=sway
systemctl --user set-environment "XDG_CURRENT_DESKTOP=${XDG_CURRENT_DESKTOP}"

unset DISPLAY WAYLAND_DISPLAY
systemctl --user unset-environment WAYLAND_DISPLAY DISPLAY

echo 'INFO  Starting gnome-keyring-daemon'

eval "$(gnome-keyring-daemon --components=ssh,secrets,pkcs11 --start)"
export GNOME_KEYRING_CONTROL SSH_AUTH_SOCK

echo 'INFO  Executing Sway now'
exec sway
