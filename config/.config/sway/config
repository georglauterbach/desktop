# ----  Resizing

bindsym $spr+r mode "Resize Mode"

set $wm.resize.size.single 60
set $wm.resize.size.multi   5
mode "Resize Mode" {
    bindsym {
        Left  resize shrink width  $wm.resize.size.single px or $wm.resize.size.multi ppt
        Right resize grow   width  $wm.resize.size.single px or $wm.resize.size.multi ppt
        Down  resize grow   height $wm.resize.size.single px or $wm.resize.size.multi ppt
        Up    resize shrink height $wm.resize.size.single px or $wm.resize.size.multi ppt
    }

    bindsym Return mode "default"
    bindsym Escape mode "default"
    bindsym $spr+r mode "default"
}

# ---- Screenshot

set $satty satty -f - --copy-command=wl-copy --actions-on-escape="save-to-clipboard,exit" --brush-smooth-history-size=5 --disable-notifications
set $mode_screenshot 'printscreen (r:region, f:full, w:window)'
mode $mode_screenshot {
    bindsym r exec swaymsg 'mode "default"' && grim -t ppm -g "$(slurp -d)" - | $satty
    bindsym f exec swaymsg 'mode "default"' && grim -t ppm - | $satty
    bindsym w exec swaymsg 'mode "default"' && swaymsg -t get_tree | jq -r '.. | select(.focused?) | .rect | "\(.x),\(.y) \(.width)x\(.height)"' | grim -t ppm -g - - | $satty

    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $spr+s mode $mode_screenshot

# ----  Media Keys

bindsym --locked XF86AudioRaiseVolume  exec wpctl set-volume "@DEFAULT_AUDIO_SINK@" "5%+"
bindsym --locked XF86AudioLowerVolume  exec wpctl set-volume "@DEFAULT_AUDIO_SINK@" "5%-"
bindsym --locked XF86AudioMute         exec wpctl set-mute   "@DEFAULT_AUDIO_SINK@"   toggle
bindsym --locked XF86AudioMicMute      exec wpctl set-mute   "@DEFAULT_AUDIO_SOURCE@" toggle

bindsym --locked XF86MonBrightnessUp   exec lightctl set '+5%'
bindsym --locked XF86MonBrightnessDown exec lightctl set '-5%'

