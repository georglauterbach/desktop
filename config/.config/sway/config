#include "${HOME}/.config/sway/user/early.conf"

# -----------------------------------------------
# ----  Initialization  -------------------------
# -----------------------------------------------

xwayland enable

# Sway does not natively support in-order startup
# of applications; hence, we use a shell script
# to get rid of this limitation.
exec "exec ${HOME}/.config/sway/init.sh"

# We need to ensure the background image is set correctly
# when we start and we reload the configuration.
exec_always "swaymsg output '*' bg \"${HOME}/.config/sway/looks/wallpaper\" fill"

# When the Sway configuration is reloaded, we need
# to ensure that the display configuration is
# correctly applied (again) and that a possible
# laptop screen remains disabled if the lid is
# closed.
#
# ref: https://gitlab.com/w0lff/shikane/-/issues/1
exec_always 'sleep 1.5s; shikanectl reload >>/tmp/.sway.shikanectl.log 2>>/tmp/.sway.shikanectl.err.log; if [ -e /proc/acpi/button/lid/LID0/state ]; then if grep -q open /proc/acpi/button/lid/LID0/state; then     swaymsg output eDP-1 enable; else swaymsg output eDP-1 disable; fi fi'

