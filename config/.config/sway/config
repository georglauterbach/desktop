# -----------------------------------------------
# ----  Key Bindings  ---------------------------
# -----------------------------------------------

# ----  Meta Key Mappings

set $spr Mod4
set $alt Mod1
set $sft Shift
set $ctl Ctrl

floating_modifier $spr

# ----  Session Management

# reload Sway
bindsym $spr+$sft+r exec swaymsg reload

# lock the screen
bindsym $spr+$sft+l exec __way_lock

# logout / exit / sleep / etc.
bindsym $spr+$sft+e exec wleave

# ----  Miscellaneous

# tile vertically or horizontally
bindsym $spr+v           split      vertical
bindsym $spr+h           split      horizontal

# fullscreen, floating and focus toggle
bindsym $spr+$sft+f      fullscreen toggle
bindsym $spr+$sft+Space  floating   toggle
bindsym $spr+$sft+t      focus      mode_toggle

# terminate a window
bindsym $spr+q           [con_id="__focused__"] kill

# application launcher
bindsym $spr+$ctl+Space exec rofi -show drun
bindsym $spr+Space      exec rofi -show combi

# terminal
bindsym $spr+Return     exec systemd-run --user --scope /usr/bin/x-terminal-emulator

# notification center
bindsym $spr+$sft+n     exec swaync-client --toggle-panel --skip-wait

